# Copier ce fichier en .env et renseigner de vraies valeurs avant un déploiement prod.
# Utilisé par : docker-compose -f docker-compose.prod.yml up --build -d

# Compte de service PocketBase utilisé par le backend (pas un compte joueur).
# L'email n'a pas besoin d'être réel, juste au format email. Mot de passe : 8 caractères min.
PB_SUPERUSER_EMAIL=admin@yourdomain.com
PB_SUPERUSER_PASSWORD=change-me-to-a-long-random-password

# Clé de signature du JWT de session (cookie access_token) — longue chaîne aléatoire.
JWT_SECRET_KEY=change-me-to-a-long-random-string
